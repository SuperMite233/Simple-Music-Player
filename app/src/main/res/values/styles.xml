<resources>
    <style name="AppTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>
    <style name="AppTheme.Light" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">#F6F8FA</item>
        <item name="android:statusBarColor">#F6F8FA</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>
    <style name="AppTheme.Dark" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#101418</item>
        <item name="android:statusBarColor">#101418</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>
    <style name="AppTheme.Dialog.Light" parent="android:style/Theme.Material.Light.Dialog.Alert">
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">#35C2A1</item>
        <item name="android:windowBackground">#FFFFFFFF</item>
        <item name="android:textColorPrimary">#111820</item>
        <item name="android:textColorSecondary">#5D6975</item>
    </style>
    <style name="AppTheme.Dialog.Dark" parent="android:style/Theme.Material.Dialog.Alert">
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">#35C2A1</item>
        <item name="android:windowBackground">#FF1A2027</item>
        <item name="android:textColorPrimary">#F4F7F8</item>
        <item name="android:textColorSecondary">#AAB5BD</item>
    </style>
</resources>
